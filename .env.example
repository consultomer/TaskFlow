# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_PATH=tasks.db

# Server
HOST=0.0.0.0
PORT=5001
DOMAIN=yourdomain.com  # e.g., example.com

# Registration (optional - leave empty to allow open registration)
REGISTRATION_TOKEN=your-secure-token-here

# Default Admin User (created automatically on startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
